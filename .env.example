# Copy to .env and fill in your REAL values. NEVER commit the real .env.
# This file is COMMITTED — keep it placeholders only. No real endpoints, hosts, buckets, or secrets.

# --- Engine HTTP server ---
# A Cloudflare Tunnel forwards https://<your-engine-subdomain> -> localhost:ENGINE_PORT
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8000
SCHEMA_VERSION=1.1

# --- Auth (shared secrets — the SAME values live in the LMS secrets) ---
# Generate each with:  openssl rand -hex 32
# ENGINE_API_TOKEN   == LMS STORY_VIDEO_ENGINE_TOKEN  (bearer; engine validates inbound jobs)
# ENGINE_HMAC_SECRET == LMS STORY_VIDEO_HMAC_SECRET   (ONE secret, BOTH directions:
#   LMS signs job requests -> engine verifies; engine signs webhooks -> LMS verifies)
ENGINE_API_TOKEN=replace-with-openssl-rand-hex-32
ENGINE_HMAC_SECRET=replace-with-openssl-rand-hex-32

# --- Outbound webhooks (engine -> LMS) ---
# Default callback if a job payload omits callback.url. == LMS STORY_VIDEO_CALLBACK_URL.
ORCHESTRATOR_WEBHOOK_URL=https://your-lms-domain.example.com/webhooks/story-video

# --- AWS S3 delivery (scoped IAM: s3:PutObject on the target bucket only) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_DEFAULT_BUCKET=your-content-bucket

# CloudFront distribution that fronts the bucket; callbacks build CDN URLs from this.
CLOUDFRONT_BASE_URL=https://your-distribution.cloudfront.net

# Per-story assets (character refs, narration audio, output video) live under:
#   {CLOUDFRONT_BASE_URL}/{ASSET_BASE_PREFIX}/{story_slug}/
# Mapping: s3_key = ASSET_BASE_PREFIX/{story_slug}/... ; cdn_url = CLOUDFRONT_BASE_URL/{s3_key}
# (the CDN path == the S3 key).
ASSET_BASE_PREFIX=your-prefix/stories

# --- Model / cache locations ---
# Defaults (~/.cache/huggingface) are fine on the 100GB disk. Leave unset to use defaults;
# only set these if you want model weights cached elsewhere.
# HF_HOME=
# MODEL_DIR=

# --- GPU budget accounting ---
GPU_BUDGET_SECONDS=108000   # ~30 hours; engine warns as cumulative usage approaches this

# --- Idle lifecycle ---
# 0 = never self-shutdown (the LMS owns VM stop via the idle webhook).
# >0 = engine triggers OS shutdown after N idle minutes (alternative strategy).
IDLE_SHUTDOWN_MINUTES=0

# --- Per-job working dir (crash-resume checkpoints; NOT a job queue) ---
# The LMS (BullMQ + Postgres) owns the durable job queue. The engine only keeps per-job
# checkpoints here so a restart resumes from the first unfinished scene (saves GPU budget).
WORK_DIR=./work
