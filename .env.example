# Copy to .env and fill in. NEVER commit the real .env.

# --- Engine HTTP server ---
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8000
CONTRACT_VERSION=1

# --- Inbound auth (Nest.js -> engine) ---
ENGINE_API_TOKEN=replace-with-long-random-token
ENGINE_HMAC_SECRET=replace-with-shared-hmac-secret

# --- Outbound webhooks (engine -> Nest.js) ---
# Default callback if a job omits one (jobs may override via payload.callback.webhook_url)
ORCHESTRATOR_WEBHOOK_URL=https://lms.example.com/genai/callbacks
ORCHESTRATOR_HMAC_SECRET=replace-with-shared-hmac-secret

# --- AWS S3 delivery (scoped IAM: s3:PutObject on the target bucket only) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_DEFAULT_BUCKET=ocw-lesson-content

# CloudFront distribution that fronts the bucket; callbacks return CDN URLs built from this.
CLOUDFRONT_BASE_URL=https://d35ivcpjrjjgk.cloudfront.net

# Asset/story layout under the CDN (and S3 key prefix). Per-story assets — character
# reference images, the ElevenLabs narration, and our output video — live under:
#   {CLOUDFRONT_BASE_URL}/{ASSET_BASE_PREFIX}/{story_slug}/
# Example story_slug: "the-weight"
# NOTE: bucket is 'ocw-lesson-content' but the CDN path starts '/lesson-content' — confirm
# the exact S3-key <-> CloudFront-path mapping before Phase 6 delivery.
ASSET_BASE_PREFIX=lesson-content/Stories-podcast

# --- Model / cache locations (kept OFF the 100GB disk root if needed) ---
HF_HOME=/opt/genai/hf_cache
MODEL_DIR=/opt/genai/models

# --- GPU budget accounting ---
GPU_BUDGET_SECONDS=252000   # ~70 hours; engine warns as cumulative usage approaches this

# --- Idle lifecycle ---
# 0 = never self-shutdown (recommended during development). >0 = OS shutdown after N idle minutes.
IDLE_SHUTDOWN_MINUTES=0

# --- Job persistence ---
QUEUE_DB_PATH=./queue_data/jobs.sqlite
